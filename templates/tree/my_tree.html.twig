{% extends 'base.html.twig' %}

{% block title %}Matrice de Parenté{% endblock %}

{% block body %}
<div class="container-fluid my-5">

    <h1 class="text-center text-primary mb-4">
        <i class="fas fa-sitemap me-2"></i> Matrice de Parenté
    </h1>

    <p class="text-center text-muted mb-4">
        Visualisez les liens familiaux entre chaque personne.
    </p>

    <div class="d-flex justify-content-end mb-4">
        <a href="{{ path('app_tree_new_person') }}" class="btn btn-success btn-lg shadow-sm">
            <i class="fas fa-user-plus me-2"></i> Ajouter une Personne
        </a>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body d-flex flex-wrap gap-4 small">
            <span><span class="badge bg-light text-muted border">—</span> Aucun lien</span>
            <span><span class="badge relation-parent-enfant">Parent / Enfant</span></span>
            <span><span class="badge relation-fratrie ">Frère / Sœur</span></span>
        </div>
    </div>

    <div class="matrix-container shadow-lg rounded overflow-auto">
        <table class="table table-bordered table-hover align-middle mb-0">

            <thead class="sticky-top bg-dark text-white">
                <tr>
                    <th class="sticky-left bg-dark text-white text-center">
                        Personne
                    </th>

                    {% for personB in people %}
                        {% set birthDate = personB.dateOfBirth ? 'Né(e) le ' ~ personB.dateOfBirth|date('d/m/Y') : 'Date inconnue' %}
                        <th class="text-center bg-primary text-white matrix-header"
                            data-bs-toggle="tooltip"
                            title="{{ personB.firstName }} {{ personB.lastName }} — {{ birthDate }}">
                            <span class="d-block text-truncate">
                                {{ personB.firstName }} {{ personB.lastName }}
                            </span>
                        </th>
                    {% endfor %}
                </tr>
            </thead>

            <tbody>
                {% for personA in people %}
                    <tr>

                        {% set birthDate = personA.dateOfBirth ? 'Né(e) le ' ~ personA.dateOfBirth|date('d/m/Y') : 'Date inconnue' %}
                        <th class="sticky-left bg-light fw-bold text-nowrap d-flex align-items-center justify-content-between"
                            data-bs-toggle="tooltip"
                            title="{{ birthDate }}">
                            
                            {# 1. Nom de la Personne #}
                            <span>
                                {{ personA.firstName }} {{ personA.lastName }}
                            </span>

                            {# 2. BOUTON ÉDITER (seulement si la personne est réelle, pas un mock) #}
                            {% if personA.id is not null %}
                                <a href="{{ path('app_tree_edit_person', {'id': personA.id}) }}" 
                                   class="btn btn-sm btn-outline-primary ms-2"
                                   title="Modifier cette personne">
                                    <i class="fas fa-edit"></i>
                                </a>
                            {% endif %}
                        </th>

                        {% for personB in people %}
                            {% set relation = formatterService.getRelationship(personA, personB) %}

                            {% set class = {
                                'Self': 'relation-self',
                                'Parent': 'relation-parent-enfant',
                                'Enfant': 'relation-parent-enfant',
                                'Frère/Sœur': 'relation-fratrie'
                            }[relation] ?? 'relation-inconnu' %}

                            <td class="{{ class }} text-center">
                                {% if relation == 'Self' %}
                                    —
                                {% elseif relation in ['Parent', 'Enfant', 'Frère/Sœur'] %}
                                    {{ relation }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>

        </table>
    </div>
</div>
{% endblock %}