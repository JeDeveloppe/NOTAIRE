{% extends 'base.html.twig' %}

{% block title %}Matrice de Parenté{% endblock %}

{% block body %}
    <div class="container-fluid my-5">
        
        <h1 class="text-center text-primary mb-3">
            <i class="fas fa-sitemap me-2"></i> Aperçu des Relations
        </h1>
        
        {# 1. Bouton d'action et Filtre/Recherche (Suggestion UX) #}
        <div class="d-flex justify-content-between align-items-center mb-4 px-3">
            <p class="text-muted d-none d-md-block m-0">
                La matrice affiche la relation entre la personne de la ligne et celle de la colonne.
            </p>

            <a href="{{ path('app_tree_new_person') }}" class="btn btn-success btn-lg shadow-sm">
                <i class="fas fa-user-plus me-2"></i> Ajouter une Personne
            </a>
        </div>
        
        <hr>

        {# 2. Conteneur de la Matrice (Gère le défilement horizontal) #}
        <div class="matrix-table shadow-lg rounded">
            <table class="table table-bordered table-hover table-sm">
                <thead>
                    <tr>
                        {# Cellule du coin - Étiquette pour la lecture #}
                        <th scope="col" class="bg-dark text-white text-center border-bottom-0 corner-cell">
                            Personne Ligne / Personne Colonne
                        </th> 
                        
                        {# Titres des colonnes (Personne B) #}
                        {% for personB in people %}
                            {% set birthDate = personB.dateOfBirth ? 'Né(e) le ' ~ personB.dateOfBirth|date('d/m/Y') : 'Date de naissance inconnue' %}
                            <th scope="col" 
                                class="bg-primary text-white p-1 matrix-header-col" 
                                data-bs-toggle="tooltip" 
                                data-bs-placement="top"
                                title="{{ personB.firstName }} {{ personB.lastName }} | {{ birthDate }}">
                                
                                <span class="d-block text-truncate">
                                    {{ personB.firstName }} {{ personB.lastName }}
                                </span>
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {# Lignes de la matrice (Personne A) #}
                    {% for personA in people %}
                        <tr class="{% if personA.id is null %}mock-row{% endif %}"> {# Marque les lignes de mocks #}
                            {# Titre de la ligne #}
                            {% set birthDate = personA.dateOfBirth ? 'Né(e) le ' ~ personA.dateOfBirth|date('d/m/Y') : 'Date de naissance inconnue' %}
                            <th scope="row" 
                                class="bg-light text-nowrap text-dark fw-bold border-end matrix-header-row" 
                                data-bs-toggle="tooltip" 
                                data-bs-placement="right"
                                title="{{ birthDate }}">
                                
                                {{ personA.firstName }} {{ personA.lastName }}
                            </th>
                            
                            {# Cellules de relation #}
                            {% for personB in people %}
                                {% set relation = formatterService.getRelationship(personA, personB) %}
                                
                                {% set class = '' %}
                                {% set cellContent = relation %}
                                
                                {# Détermination de la classe CSS #}
                                {% if relation == 'Self' %}
                                    {% set class = 'relation-self' %}
                                    {% set cellContent = '—' %}
                                {% elseif relation == 'Parent' or relation == 'Enfant' %}
                                    {% set class = 'relation-parent-enfant' %}
                                {% elseif relation == 'Frère/Sœur' %}
                                    {% set class = 'relation-fratrie' %}
                                {% else %}
                                    {% set class = 'relation-inconnu' %}
                                    {% set cellContent = '—' %}
                                {% endif %}
                                
                                <td class="{{ class }} {% if personB.id is null %}mock-cell{% endif %}">
                                    {% if cellContent == 'Self' or cellContent == 'Inconnu' %}
                                        —
                                    {% else %}
                                        {{ cellContent }}
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}