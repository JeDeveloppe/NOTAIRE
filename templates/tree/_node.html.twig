{# templates/tree/_node.html.twig #}

<div class="tree-node-group">
    
    {# Conteneur pour le Nœud et le Conjoint (Union) #}
    <div class="union-container">
    
        {# 1. Affichage de la personne principale (Jean) #}
        <div 
            class="node-card {{ person.className }}" 
            data-id="{{ person.id }}"
        >
            <strong>{{ person.name }}</strong>
            <br>
            <small>{{ person.title }} (Né: {{ person.dob }})</small>
        </div>
        
        {# 2. Affichage du Conjoint (Marie) s'il existe #}
        {% if person.spouse is defined and person.spouse is not empty %}
            <div 
                class="node-card spouse-card {{ person.spouse.className }}" 
                data-id="{{ person.spouse.id }}"
            >
                <strong>{{ person.spouse.name }} (Conjoint)</strong>
                <br>
                <small>{{ person.spouse.title }} (Né: {{ person.spouse.dob }})</small>
            </div>
        {% endif %}
        
    </div> 
    {# Fin union-container #}
    
    {# 3. Rendu récursif des enfants (attaché au couple) #}
    {% if person.children is not empty %}
        <ul class="children-list">
            {% for child in person.children %}
                <li class="child-item">
                    {# Appel récursif pour chaque enfant #}
                    {% include 'tree/_node.html.twig' with {'person': child} %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}

</div>