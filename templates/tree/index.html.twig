{# templates/tree/custom_index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Arbre Généalogique Personnalisé{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    
    <link rel="stylesheet" href="{{ asset('css/family-tree.css') }}">
    
    <style>
        /* CSS DE BASE pour l'arbre */
        #custom-tree {
            padding: 20px;
            text-align: center; /* Centrer l'arbre */
        }
        
        /* Les noeuds sont alignés horizontalement */
        .tree-node-group {
            display: flex;
            justify-content: center;
        }

        /* Le noeud principal */
        .node-card {
            border: 1px solid #ccc;
            padding: 10px;
            margin: 10px;
            display: inline-block;
            min-width: 150px;
            border-radius: 8px;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
            text-align: left;
        }
        
        /* Personne connectée */
        .current-user-node {
            background-color: #007bff;
            color: white;
            border-color: gold;
        }
        
        /* Décédé */
        .deceased-node {
            background-color: #f0f0f0;
            opacity: 0.7;
            font-style: italic;
        }
        
        /* C'est dans le CSS que la magie des lignes d'arbre est gérée, en stylisant les ul/li */
        /* La logique est trop longue pour être incluse ici, mais elle utilise des pseudo-éléments (:before, :after) */
    </style>
{% endblock %}

{% block body %}
    <div class="container my-5">
        <h1 class="mb-4">Mon Arbre Généalogique Héritage Flow</h1>
        
        {% if root_nodes is not empty %}
            <div id="custom-tree">
                {% for node in root_nodes %}
                    {# Inclure le template récursif pour chaque racine #}
                    {% include 'tree/_node.html.twig' with {'person': node} %}
                {% endfor %}
            </div>
        {% else %}
            <p class="alert alert-warning">Veuillez ajouter des personnes pour construire votre arbre.</p>
        {% endif %}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {# Pas de librairie JS requise, sauf si vous voulez ajouter de l'interactivité. #}
{% endblock %}