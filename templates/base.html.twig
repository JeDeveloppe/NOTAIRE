{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Planification Fiscale{% endblock %}</title>
        
        {# NOUVEAU : CSS de Bootstrap 5 #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        
        {# NOUVEAU : Font Awesome pour les icônes (si vous l'utilisez) #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLMDJ8gP3rXJ3PjC3F+yV8pLp+rR+k5XqP5xT+M9R+A2/G5uK/Q8e4Y3p2g5l5w==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        
        <link rel="icon" href="{{ asset('favicon.ico') }}">
        
        {% block stylesheets %}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
        
    </head>
    <body>
        
        {# --- EMPLACEMENT DE LA NAVBAR --- #}
        {% include '_nav.html.twig' %}
        {# --- FIN DE LA NAVBAR --- #}
        
        {# Un conteneur général Bootstrap pour centrer et limiter la largeur du CONTENU #}
        <div class="container-fluid">
            {% block body %}{% endblock %}
        </div>
        
        {# JS de Bootstrap 5 #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>