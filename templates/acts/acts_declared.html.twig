{# Fichier : templates/simulation/declare_acts.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Déclaration des actes de donation passés{% endblock %}

{% block body %}
    <div class="container my-5">
        <h1 class="mb-4 text-primary">
            <i class="fas fa-file-invoice-dollar me-2"></i> Historique des donations déclarées
        </h1>
        
        {# MESSAGE D'INFORMATION ADAPTÉ SANS AUCUN GRAS MARKDOWN #}
        <div class="alert alert-info shadow-sm">
            <i class="fas fa-info-circle me-2"></i> 
            Veuillez déclarer toutes les donations passées pour une simulation précise :
            <ul>
                {# CORRECTION : Remplacement de **15 ans** par 15 ans #}
                <li>Pour les abattements classiques (Parent ➡️ Enfant, etc.) : Tous les actes effectués il y a moins de 15 ans sont pris en compte pour le calcul du solde restant.</li>
                <li>Pour le don Sarkozy (don familial de sommes d'argent) : L'enveloppe est unique et définitive. Tous les actes passés, quelle que soit leur date, doivent être déclarés pour connaître le solde.</li>
            </ul>
            <p class="mt-2 mb-0 small fst-italic">
                Pour en savoir plus sur les règles et abattements, consultez le <a href="{{ path('app_acts_fiscal_summary') }}">lexique fiscal</a>.
            </p>
        </div>

        <div class="card shadow">
            <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                <span class="fw-bold">
                    <i class="fas fa-history me-1"></i> Actes enregistrés
                </span>
                
                {# BOUTON QUI OUVRE LA MODALE D'AJOUT #}
                <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addActModal">
                    <i class="fas fa-plus-circle me-1"></i> Déclarer un nouvel acte
                </button>
            </div>
            
            <div class="card-body p-0">
                {% if existingActs is empty %}
                    <div class="alert alert-warning m-3 text-center">
                        Aucune donation n'a été déclarée pour l'instant.
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">Relation</th>
                                    <th scope="col">Type d'acte</th>
                                    <th scope="col" class="text-center">Date</th>
                                    <th scope="col" class="text-end">Montant du Don</th>
                                    <th scope="col" class="text-end">Impact Abattement</th>
                                    <th scope="col" class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for act in existingActs %}
                                    {% set typeAct = act.typeOfAct %}
                                    {% set is_sarkozy = typeAct and typeAct.code == 'SARKOZY' %} 
                                    {% set amount_euro = act.value / 100 %}

                                    <tr>
                                        {# 1. RELATION #}
                                        <td>
                                            <span class="fw-bold">{{ act.donor.firstName }}</span> ➡️ <span class="fw-bold">{{ act.beneficiary.firstName }}</span>
                                        </td>
                                        
                                        {# 2. TYPE D'ACTE #}
                                        <td>
                                            <span class="badge bg-{% if is_sarkozy %}info{% else %}primary{% endif %}">
                                                {{ typeAct ? typeAct.name : 'Inconnu' }}
                                            </span>
                                        </td>
                                        
                                        {# 3. DATE #}
                                        <td class="text-center">
                                            {{ act.dateOfAct|date('d/m/Y') }}
                                        </td>
                                        
                                        {# 4. MONTANT DU DON #}
                                        <td class="text-end fw-bold text-dark">
                                            {{ amount_euro | number_format(0, ',', ' ') }} €
                                        </td>
                                        
                                        {# 5. IMPACT ABATTEMENT #}
                                        <td class="text-end">
                                            {% if act.consumedAbatement > 0 %}
                                                <span class="fw-bold text-danger">
                                                    - {{ (act.consumedAbatement / 100)|number_format(0, ',', ' ') }} €
                                                </span>
                                            {% else %}
                                                <span class="text-success">Exonéré</span>
                                            {% endif %}
                                        </td>
                                        
                                        {# 6. ACTIONS #}
                                        <td class="text-center text-nowrap">
                                            <a href="#" class="btn btn-sm btn-outline-primary me-1" title="Modifier l'acte"><i class="fas fa-edit"></i></a>
                                            <a href="#" class="btn btn-sm btn-outline-danger" title="Supprimer l'acte"><i class="fas fa-trash"></i></a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
        
        {# BOUTON DE REDIRECTION VERS LA SIMULATION #}
        <div class="text-end mt-4">
             {% if canLaunchSimulation is defined and canLaunchSimulation %}
                <a href="{{ path('app_simulation_planning_donataires') }}" class="btn btn-primary btn-lg shadow">
                    <i class="fas fa-chart-line me-2"></i> Lancer la planification fiscale
                </a>
            {% else %}
                <div class="alert alert-warning d-inline-block p-2 m-0 small">
                    <i class="fas fa-user-friends me-1"></i> 
                    Vous devez être au moins 2 membres de votre famille avant de lancer la simulation.
                </div>
                <div class="d-flex justify-content-end mt-4">
                    <a href="{{ path('app_tree_new_person') }}" class="btn btn-success btn-lg shadow-sm">
                        <i class="fas fa-user-plus me-2"></i> Ajouter une Personne
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
    
    {# ========================================== #}
    {#                 LA MODALE D'AJOUT            #}
    {# ========================================== #}
    <div class="modal fade" id="addActModal" tabindex="-1" aria-labelledby="addActModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="addActModalLabel">
                        <i class="fas fa-plus-circle me-1"></i> Déclarer un nouvel acte de donation
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                {{ form_start(actForm) }}
                <div class="modal-body">
                    <div class="alert alert-warning small">
                        Attention : Le montant doit être saisi en euros entiers (sans centimes).
                    </div>
                    
                    {{ form_row(actForm.donor) }}
                    {{ form_row(actForm.beneficiary) }}
                    {{ form_row(actForm.typeOfAct) }}
                    
                    {{ form_row(actForm.value, {
                        'label': 'Montant en euros (€)',
                        'attr': {'placeholder': 'Ex: 100000'}
                    }) }}
                    
                    {{ form_row(actForm.dateOfAct) }}
                    
                    {{ form_errors(actForm) }}

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save me-1"></i> Enregistrer et Mettre à Jour
                    </button>
                </div>
                {{ form_end(actForm) }}
            </div>
        </div>
    </div>
{% endblock %}