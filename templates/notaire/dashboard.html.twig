{% extends 'base_notaire.html.twig' %}

{% block title %}Tableau de Bord Notaire{% endblock %}

{% block body %}
    <div class="container my-5">
        
        {% if notaryOffice is null %}
            {# --- ÉCRAN DE BIENVENUE (Si l'étude n'existe pas encore) --- #}
            <div class="row justify-content-center">
                <div class="col-md-8 text-center">
                    <div class="card shadow border-0 p-5 bg-white">
                        <div class="mb-4">
                            <span class="fa-stack fa-4x">
                                <i class="fas fa-circle fa-stack-2x text-light"></i>
                                <i class="fas fa-building fa-stack-1x text-primary"></i>
                            </span>
                        </div>
                        <h2 class="fw-bold">Bienvenue sur votre espace !</h2>
                        <p class="text-muted lead mb-4">
                            Pour activer vos outils professionnels et découvrir les prospects dans votre secteur, 
                            vous devez d'abord configurer les informations de votre étude.
                        </p>
                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                            <a href="{{ path('notaire_edit_office') }}" class="btn btn-primary btn-lg px-4 gap-3 shadow">
                                <i class="fas fa-plus-circle me-2"></i>Configurer mon étude
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        {% else %}
            {# --- TABLEAU DE BORD ACTIF (Si l'étude existe) --- #}
            
            {# En-tête #}
            <div class="row mb-4">
                <div class="col-12">
                    <div class="d-flex align-items-center justify-content-between">
                        <h1 class="text-primary mb-0">
                            <i class="fas fa-gavel me-2"></i> Espace Professionnel
                        </h1>
                        <span class="badge bg-white text-dark border p-2 shadow-sm">
                            <i class="fas fa-calendar-alt me-1 text-primary"></i> {{ "now"|date("d/m/Y") }}
                        </span>
                    </div>
                    <p class="lead mt-3 text-muted">
                        Bienvenue, <strong>{{ app.user.email }}</strong>. 
                        Suivi de l'activité pour l'étude <strong>{{ notaryOffice.name }}</strong> ({{ notaryOffice.city.name|default('Ville non définie') }}).
                    </p>
                    <hr>
                </div>
            </div>

            {# Section Cartes de Statistiques #}
            <div class="row mb-5 g-4">
                {# Carte Potentiel (Basée sur le rayon) #}
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 bg-primary text-white overflow-hidden">
                        <div class="card-body position-relative">
                            <div class="d-flex justify-content-between align-items-start position-relative" style="z-index: 2;">
                                <div>
                                    <h5 class="card-title opacity-75">Potentiel Local</h5>
                                    <p class="display-4 fw-bold mb-0">{{ potentialClients }}</p>
                                </div>
                                <i class="fas fa-map-marked-alt fa-3x opacity-25"></i>
                            </div>
                            <p class="mt-3 mb-0 position-relative" style="z-index: 2;">
                                <i class="fas fa-bullseye me-1 text-warning"></i> Prospects à <strong>{{ notaryOffice.radius|default(25) }} km</strong>
                            </p>
                        </div>
                        <div class="card-footer bg-dark bg-opacity-10 border-0">
                            <a href="{{ path('notaire_edit_office') }}" class="btn btn-sm btn-light w-100 text-primary fw-bold">
                                Ajuster mon périmètre
                            </a>
                        </div>
                    </div>
                </div>

                {# Carte Dossiers #}
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 bg-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="card-title opacity-75">Dossiers Actifs</h5>
                                    <p class="display-4 fw-bold mb-0">12</p>
                                </div>
                                <i class="fas fa-folder-open fa-3x opacity-25"></i>
                            </div>
                            <p class="mt-3 mb-0 text-white-50 small">Accompagnements en cours via la plateforme.</p>
                        </div>
                    </div>
                </div>

                {# Carte Temps Réel #}
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 bg-white border">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            <h6 class="text-muted text-uppercase small fw-bold mb-3">Dernière Connexion</h6>
                            <p class="h2 mb-0 text-dark font-monospace">{{ "now"|date("H:i") }}</p>
                            <div class="mt-3">
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2">
                                    <i class="fas fa-check-circle me-1"></i> Système Opérationnel
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Section Actions & Liens #}
            <div class="row">
                {# Bloc Consultation Client #}
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-dark text-white fw-bold py-3">
                            <i class="fas fa-search me-2 text-info"></i> Consultation Simulation
                        </div>
                        <div class="list-group list-group-flush">
                            <a href="#" class="list-group-item list-group-item-action py-3 border-start border-4 border-info">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1 fw-bold">Saisir un code client</h6>
                                    <i class="fas fa-chevron-right text-muted small"></i>
                                </div>
                                <p class="mb-0 small text-muted text-truncate">Accéder aux résultats chiffrés d'un simulateur.</p>
                            </a>
                            <a href="#" class="list-group-item list-group-item-action py-3">
                                <i class="fas fa-history me-2 text-muted"></i> Historique de mes consultations
                            </a>
                        </div>
                    </div>
                </div>

                {# Bloc Zone Géographique #}
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-dark text-white fw-bold py-3">
                            <i class="fas fa-user-tie me-2 text-success"></i> Secteur & Clientèle
                        </div>
                        <div class="list-group list-group-flush">
                            <a href="#" class="list-group-item list-group-item-action py-3 list-group-item-success">
                                <div class="d-flex w-100 justify-content-between align-items-center">
                                    <h6 class="mb-0 fw-bold"><i class="fas fa-users me-2"></i>Prospects à proximité</h6>
                                    <span class="badge bg-success rounded-pill px-3 fs-6">{{ potentialClients }}</span>
                                </div>
                            </a>
                            <a href="{{ path('notaire_edit_office') }}" class="list-group-item list-group-item-action py-3">
                                <i class="fas fa-cog me-2 text-muted"></i> Paramètres de l'étude (Adresse & Rayon)
                            </a>
                        </div>
                    </div>
                </div>

                {# Raccourcis Outils (Barre horizontale) #}
                <div class="col-12 mt-2">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="row text-center g-3">
                                <div class="col-6 col-md-3 border-end-md">
                                    <a href="#" class="text-decoration-none text-dark d-block p-2">
                                        <i class="fas fa-plus-circle fa-2x text-success mb-2"></i>
                                        <p class="small fw-bold mb-0">Nouvel Acte</p>
                                    </a>
                                </div>
                                <div class="col-6 col-md-3 border-end-md">
                                    <a href="#" class="text-decoration-none text-dark d-block p-2">
                                        <i class="fas fa-calculator fa-2x text-warning mb-2"></i>
                                        <p class="small fw-bold mb-0">Calcul Frais</p>
                                    </a>
                                </div>
                                <div class="col-6 col-md-3 border-end-md">
                                    <a href="#" class="text-decoration-none text-dark d-block p-2">
                                        <i class="fas fa-envelope-open-text fa-2x text-info mb-2"></i>
                                        <p class="small fw-bold mb-0">Modèles Actes</p>
                                    </a>
                                </div>
                                <div class="col-6 col-md-3">
                                    <a href="#" class="text-decoration-none text-dark d-block p-2">
                                        <i class="fas fa-headset fa-2x text-danger mb-2"></i>
                                        <p class="small fw-bold mb-0">Support</p>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    <style>
        .border-end-md { border-right: 1px solid #dee2e6; }
        @media (max-width: 767.98px) { .border-end-md { border-right: none; } }
        .list-group-item:hover { background-color: #f8f9fa; }
        .card { transition: transform 0.2s ease; }
        .card:hover { transform: translateY(-2px); }
    </style>
{% endblock %}