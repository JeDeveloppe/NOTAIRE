{% extends 'base.html.twig' %}

{% block title %}Planification des Cycles de Donation - T0 et T1{% endblock %}

{% block body %}
    <div class="container-fluid my-5">
        <h1 class="mb-5 text-center text-success"><i class="fas fa-sync-alt me-2"></i> Planification Fiscale : Cycles d'Abattement</h1>
        
        <div class="alert alert-info text-center shadow-sm">
            <i class="fas fa-info-circle me-2"></i> Les opportunités sont affichées pour l'Année en cours (T0) et le Prochain cycle de renouvellement complet (T1).
        </div>
        
        {% if plan.cycles is empty %}
            <div class="alert alert-warning text-center mt-5">
                <i class="fas fa-exclamation-triangle me-2"></i> Aucune opportunité d'abattement n'a été calculée pour l'instant.
            </div>
        {% else %}
        
            {% set current_year = ("now"|date("Y")) + 0 %} 
            {% set future_cycles = [] %}
            
            {% for cycle in plan.cycles %}
                {% if cycle.year >= current_year %}
                    {% set future_cycles = future_cycles|merge([cycle]) %}
                {% endif %}
            {% endfor %}

            {% set cycles_to_display = future_cycles|slice(0, 2) %}

            {% if cycles_to_display is empty %}
                <div class="alert alert-info text-center mt-5">
                    Aucune opportunité future ou cycle en cours n'a été trouvé dans les données.
                </div>
            {% else %}
            
                {# --- 3. AFFICHAGE DES CYCLES FILTRÉS --- #}
                {% for cycle in cycles_to_display %}
                    
                    {% set year = cycle.year %}
                    {% set is_current_year = year == current_year %}
                    {% set cycle_accordion_id = 'accordionCycle' ~ year %}
                    
                    {# --- DÉBUT DU GROUPE DE CYCLE PAR ANNÉE (CONTENEUR PRINCIPAL) --- #}
                    <div class="card mb-5 shadow-lg {% if is_current_year %}border-danger{% else %}border-success{% endif %}">
                        <div class="card-header bg-{% if is_current_year %}danger{% else %}success{% endif %} text-white p-3">
                            <h4 class="mb-0">
                                <i class="fas fa-calendar-check me-2"></i> Cycle disponible en Année {{ year }}
                                {% if is_current_year %}
                                    <span class="badge bg-light text-danger ms-2">OPPORTUNITÉ IMMÉDIATE</span>
                                {% else %}
                                    <span class="badge bg-light text-success ms-2">PROCHAIN CYCLE FISCAL</span>
                                {% endif %}
                            </h4>
                        </div>
                        
                        <div class="card-body p-0">
                            {# Re-introduire l'accordéon pour le niveau Donneurs #}
                            <div class="accordion accordion-flush" id="{{ cycle_accordion_id }}">
                            
                            {# Itérer sur les donneurs (ACCORDÉON ITEM) #}
                            {% for donorId, donorData in cycle.actions_grouped %}
                                
                                {% set first_action = donorData.actions_by_beneficiary|first|first %}
                                {% set donor_name = first_action.donor_name %}
                                {% set donor_age = first_action.donor_age %}
                                {% set donor_unique_id = 'donor-' ~ year ~ '-' ~ donorId %}
                                
                                <div class="accordion-item border-top">
                                    <h2 class="accordion-header" id="heading{{ donor_unique_id }}">
                                        <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ donor_unique_id }}" aria-expanded="false" aria-controls="collapse{{ donor_unique_id }}">
                                            <i class="fas fa-user-circle me-2 text-primary"></i> 
                                            Donateur : {{ donor_name }} ({{ donor_age }} ans)
                                            <span class="badge bg-secondary ms-3">{{ donorData.actions_by_beneficiary|length }} Opportunité(s)</span>
                                        </button>
                                    </h2>
                                    
                                    <div id="collapse{{ donor_unique_id }}" class="accordion-collapse collapse" aria-labelledby="heading{{ donor_unique_id }}" data-bs-parent="#{{ cycle_accordion_id }}">
                                        
                                        {# --- CONTENU À DEUX COLONNES --- #}
                                        <div class="accordion-body p-3">
                                            <div class="row">
                                            
                                                {# COLONNE GAUCHE (4/12) : CARTE DU DONATEUR PRINCIPAL #}
                                                <div class="col-md-4 mb-3 mb-md-0">
                                                    <div class="card bg-light border-primary h-100 shadow-sm">
                                                        <div class="card-header bg-primary text-white">
                                                            <i class="fas fa-hand-holding-usd me-1"></i> Source des Dons
                                                        </div>
                                                        <div class="card-body">
                                                            <h5 class="card-title text-primary">{{ donor_name }}</h5>
                                                            <p class="card-text small mb-1">
                                                                <i class="fas fa-birthday-cake me-1"></i> Âge actuel : {{ donor_age }} ans
                                                            </p>
                                                            <p class="card-text small text-muted mb-0">
                                                                Les opportunités listées à droite sont basées sur le cycle fiscal de cette personne.
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                            
                                                {# COLONNE DROITE (8/12) : LISTE DES BÉNÉFICIAIRES ET ALERTES #}
                                                <div class="col-md-8">
                                                    <h6 class="mb-2">Destinataires & Calendrier :</h6>
                                                    <ul class="list-group list-group-flush border rounded">
                                                    
                                                    {% for beneficiaryKey, actions in donorData.actions_by_beneficiary %}
                                                        
                                                        {% set first_action = actions|first %}
                                                        {% set is_imperative_alert = first_action.is_imperative %}
                                                        
                                                        {% if is_imperative_alert %}
                                                            {# --- CAS 1 : ALERTE IMPÉRATIVE (MIS EN AVANT) --- #}
                                                            <li class="list-group-item d-flex flex-column bg-danger-subtle p-3">
                                                                <div class="d-flex align-items-center">
                                                                    <i class="fas fa-exclamation-triangle fa-2x me-3 text-danger"></i>
                                                                    <div>
                                                                        <h6 class="mb-0 text-danger fw-bold text-uppercase">
                                                                            URGENT : {{ first_action.relationship }}
                                                                        </h6>
                                                                        <p class="mb-0 small text-dark">{{ first_action.detail }}</p>
                                                                    </div>
                                                                </div>
                                                            </li>
                                                        {% else %}
                                                            {# --- CAS 2 : OPPORTUNITÉ CLASSIQUE --- #}
                                                            
                                                            {% set beneficiary_name = first_action.beneficiary_name %}
                                                            {% set relationship = first_action.relationship %}
                                                            {% set beneficiary_age = first_action.beneficiary_age %}
                                                            
                                                            {% set relationship_icon = (
                                                                relationship == 'parent_enfant' ? 'fas fa-user-friends' : 
                                                                relationship == 'grand_parent_petit_enfant' ? 'fas fa-baby-carriage' : 
                                                                relationship == 'frere_soeur' ? 'fas fa-handshake' : 
                                                                'fas fa-user'
                                                            ) %}

                                                            <li class="list-group-item d-flex flex-column p-3">
                                                                
                                                                {# Ligne Bénéficiaire et Âges #}
                                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                                    <h6 class="mb-0 text-dark">
                                                                        <i class="{{ relationship_icon }} me-2 text-success"></i> Bénéficiaire : {{ beneficiary_name }}
                                                                        <span class="badge bg-secondary ms-2">{{ relationship | replace({'_': ' '}) }}</span>
                                                                    </h6>
                                                                    <div class="small text-end">
                                                                        <span class="text-success">Âge : {{ beneficiary_age }} ans</span>
                                                                    </div>
                                                                </div>
                                                                
                                                                <hr class="my-2">

                                                                {# Détails des Abattements #}
                                                                {% for action in actions %}
                                                                    {% set is_sarkozy = action.type == 'Don_Sarkozy_Cumulable' %}
                                                                    
                                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                                        <span class="small text-muted">
                                                                            {# LIBELLÉ CORRIGÉ : Afficher le terme "disponible" #}
                                                                            {{ is_sarkozy ? 'Don Sarkozy disponible' : 'Abattement Patrimonial disponible' }} :
                                                                        </span>
                                                                        <span class="fw-bold {% if is_sarkozy %}text-info{% else %}text-success{% endif %}" style="font-size: 1.1em;">
                                                                            <i class="fas fa-euro-sign me-1"></i> {{ (action.abattement / 100) | number_format(0, ',', ' ') }} €
                                                                        </span>
                                                                    </div>
                                                                {% endfor %}
                                                                
                                                                {# CORRECTION DU BOUTON : Alignement à droite #}
                                                                <div class="d-flex justify-content-end mt-3">
                                                                    <button class="btn btn-sm btn-primary shadow-sm">Planifier l'acte</button>
                                                                </div>
                                                            </li>
                                                        {% endif %}
                                                    {% endfor %}
                                                    
                                                    </ul>
                                                </div>
                                                {# FIN COLONNE DROITE #}
                                                
                                            </div>
                                        </div>
                                        {# --- FIN CONTENU À DEUX COLONNES --- #}
                                        
                                    </div>
                                </div>
                            {% endfor %}
                            
                            </div>
                        </div>
                    </div>
                    {# --- FIN DU GROUPE DE CYCLE PAR ANNÉE (CONTENEUR PRINCIPAL) --- #}

                {% endfor %}
            {% endif %}
        
        {% endif %}
    </div>
{% endblock %}