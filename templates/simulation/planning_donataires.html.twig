{% extends 'base.html.twig' %}

{% block title %}Opportunités et Planification Fiscale - Vue Détail{% endblock %}

{% block body %}
<div class="container-fluid my-5">

    <h1 class="mb-5 text-center text-primary">
        <i class="fas fa-piggy-bank me-2"></i> Planification Fiscale Détaillée
    </h1>

    <div class="alert alert-info text-center shadow-sm">
        <i class="fas fa-info-circle me-2"></i> Vue détaillée des opportunités fiscales, historiques de consommation, et plan de reconstitution par paire Donateur ➡️ Bénéficiaire.
    </div>

    {# --- 1. AFFICHAGE DES ALERTES GLOBALES ET IMPÉRATIVES (Alertes Sarkozy 80 ans) --- #}
    {% if plan.future_actions.ALERTS is defined and plan.future_actions.ALERTS is not empty %}
        <h2 class="mt-5 mb-3 text-warning"><i class="fas fa-exclamation-triangle me-2"></i> Alertes Impératives</h2>
        <div class="row row-cols-1 row-cols-md-2 g-4 mb-5">
            {% for alert in plan.future_actions.ALERTS %}
            <div class="col">
                <div class="alert alert-danger-subtle border-danger border-2 shadow-sm p-3 h-100 d-flex align-items-center">
                    <i class="fas fa-exclamation-circle fa-2x me-3 text-danger"></i>
                    <div>
                        <h6 class="text-danger mb-1">{{ alert.type|replace({'_':' '}) }} en {{ alert.year }}</h6>
                        <p class="mb-0 small text-dark">{{ alert.detail ?? 'Action nécessaire avant l’échéance fiscale.' }}</p>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

    {# --- 2. FILTRE ET AFFICHAGE PRINCIPAL : OPPORTUNITÉS PAR PAIRE --- #}
    
    {# Sélecteur de Filtre #}
    <div class="mb-4 d-flex align-items-center">
        <label for="filter-relationship" class="form-label me-3 fw-bold">Filtrer par Relation :</label>
        <select id="filter-relationship" class="form-select w-auto">
            <option value="all">Toutes les Relations</option>
            <option value="descendant">Ligne Descendante (Parent/Grand-Parent)</option>
            <option value="lateral">Ligne Latérale (Frère/Sœur)</option>
            <option value="epoux">Époux</option>
            <option value="tiers">Autres (Inconnu)</option>
        </select>
    </div>
    <hr>
    
    <h2 class="mt-5 mb-3 text-success"><i class="fas fa-link me-2"></i> Opportunités par Relations</h2>
    
    {% if plan.opportunities is empty %}
        <div class="alert alert-warning text-center mt-5">
            Aucune relation fiscale pertinente n'a été trouvée pour les membres du foyer.
        </div>
    {% else %}
        
        <div class="accordion accordion-flush" id="accordionPairs">
        {% for pairKey, pairData in plan.opportunities %}
            {% set pairId = 'pair-' ~ pairData.donor_id ~ '-' ~ pairData.beneficiary_id %}

            {# LIGNE CLÉ : AJOUT DE L'ATTRIBUT data-relationship-type SUR LA CARTE #}
            <div class="card mb-4 shadow-sm border-top border-primary border-3"
                 data-relationship-type="{{ pairData.relationship_type }}">
                
                {# En-tête de la Paire #}
                <div class="card-header bg-light p-3">
                    <h5 class="mb-0">
                        <button class="btn btn-link w-100 text-start text-dark fw-bold collapsed" type="button" 
                                data-bs-toggle="collapse" data-bs-target="#collapse{{ pairId }}" 
                                aria-expanded="false" aria-controls="collapse{{ pairId }}">
                            <i class="fas fa-user-tag me-2 text-primary"></i> 
                            {{ pairData.donor_name }} ➡️ {{ pairData.beneficiary_name }}
                            <span class="badge bg-secondary ms-3">{{ pairData.relationship_type|replace({'_':' '}) }}</span>
                        </button>
                    </h5>
                </div>

                {# Contenu de la Paire (Types d'Actes) #}
                <div id="collapse{{ pairId }}" class="accordion-collapse collapse" data-bs-parent="#accordionPairs">
                    <div class="card-body p-4">

                        <div class="row g-4">
                        {% for actType, actData in pairData.fiscal_acts %}
                            {% set is_sarkozy = actType == 'Don_Sarkozy_Cumulable' %}
                            
                            <div class="col-md-6">
                                <div class="card h-100 border-{% if is_sarkozy %}info{% else %}success{% endif %} shadow-sm">
                                    <div class="card-header bg-{% if is_sarkozy %}info{% else %}success{% endif %} text-white fw-bold">
                                        <i class="fas fa-hand-holding-heart me-1"></i> {{ actType|replace({'_':' '}) }}
                                    </div>
                                    <div class="card-body">
                                        
                                        {# STATUT IMMÉDIAT (T0) #}
                                        <h6 class="text-{% if is_sarkozy %}info{% else %}success{% endif %} mb-3">
                                            <i class="fas fa-calendar-check me-1"></i> Solde Disponible Actuellement
                                        </h6>
                                        <p class="h4 fw-bold">
                                            {{ (actData.current_status.available_now / 100)|number_format(0, ',', ' ') }} €
                                            {% if actData.current_status.available_now > 0 and not is_sarkozy %}
                                                <span class="badge bg-success-subtle text-success ms-2 small">Renouvelable</span>
                                            {% elseif actData.current_status.available_now > 0 and is_sarkozy %}
                                                <span class="badge bg-info-subtle text-info ms-2 small">Enveloppe à vie</span>
                                            {% endif %}
                                        </p>
                                        <p class="small text-muted mb-4">
                                            Abattement maximum : {{ (actData.max_amount / 100)|number_format(0, ',', ' ') }} €
                                        </p>
                                        
                                        <hr>

                                        {# HISTORIQUE ET PRESCRIPTION #}
                                        <h6 class="mb-2"><i class="fas fa-history me-1"></i> Historique des Consommations</h6>
                                        {% if actData.past_acts is empty %}
                                            <p class="small text-success">Aucune consommation enregistrée dans les 15 dernières années.</p>
                                        {% else %}
                                            <ul class="list-group list-group-flush small">
                                                {% for act in actData.past_acts %}
                                                    <li class="list-group-item d-flex justify-content-between align-items-center p-1">
                                                        <span>
                                                            <i class="fas fa-file-invoice me-1"></i> Acte du {{ act.date|date('d/m/Y') }}
                                                        </span>
                                                        <span class="fw-bold text-danger">
                                                            - {{ (act.consumed / 100)|number_format(0, ',', ' ') }} €
                                                        </span>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                            <p class="small mt-2 text-danger">Total consommé : {{ (actData.current_status.consumed / 100)|number_format(0, ',', ' ') }} €</p>
                                        {% endif %}
                                        
                                        {% if not is_sarkozy %}
                                            <hr>

                                            {# PLANIFICATION FUTURE (RECONSTITUTION) #}
                                            <h6 class="mb-2"><i class="fas fa-forward me-1"></i> Planification de Reconstitution (15 ans)</h6>
                                            {% if actData.future_plans is empty and actData.current_status.consumed > 0 %}
                                                <p class="small text-muted">L'abattement consommé est déjà prescrit, ou les futures reconstitutions sont au-delà de 75 ans.</p>
                                            {% elseif actData.future_plans is empty and actData.current_status.consumed == 0 %}
                                                <p class="small text-muted">Aucune reconstitution à planifier (l'abattement n'a pas été utilisé).</p>
                                            {% else %}
                                                <ul class="list-group list-group-flush small">
                                                    {% for year, plans in actData.future_plans %}
                                                        {% for plan in plans %}
                                                            <li class="list-group-item d-flex justify-content-between align-items-center p-1 bg-light-success">
                                                                <span class="fw-bold text-success">
                                                                    <i class="fas fa-calendar-alt me-1"></i> {{ plan.reconstitution_year }}
                                                                </span>
                                                                <span class="fw-bold text-success">
                                                                    + {{ (plan.amount / 100)|number_format(0, ',', ' ') }} €
                                                                </span>
                                                            </li>
                                                        {% endfor %}
                                                    {% endfor %}
                                                </ul>
                                            {% endif %}
                                        {% endif %}

                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                        </div>

                    </div>
                </div>
            </div>
        {% endfor %}
        </div>
    {% endif %}

    {# --- 3. ACTIONS FUTURES PAR ANNÉE (Amélioré pour l'UX mobile) --- #}
    {% if plan.future_actions is not empty %}
        <h2 class="mt-5 mb-3 text-secondary"><i class="fas fa-cogs me-2"></i> Toutes les Actions Planifiées par Année</h2>
        <p class="small text-muted">Détail technique : Liste de toutes les opportunités T0 et reconstitutions futures triées par année fiscale.</p>
        
        {# Utilisation de table-responsive pour améliorer l'affichage sur petit écran #}
        <div class="table-responsive"> 
            <table class="table table-bordered table-striped small">
                <thead class="table-dark">
                    <tr>
                        <th class="text-nowrap">Année</th>
                        <th>Donateur ➡️ Bénéficiaire</th>
                        <th class="text-nowrap">Type d'Action</th>
                        <th class="text-nowrap">Montant (€)</th>
                        {# Masquer le détail sur les téléphones (extra-small screens) #}
                        <th class="d-none d-sm-table-cell">Détail</th> 
                    </tr>
                </thead>
                <tbody>
                    {% for action in plan.future_actions %}
                        {% set donor_name = plan.people[action.donor_id].name ?? 'N/A' %}
                        {% set beneficiary_name = plan.people[action.beneficiary_id].name ?? 'N/A' %}
                        
                        <tr class="{% if action.type|slice(-3) == '_T0' %}table-success{% endif %}">
                            <td class="fw-bold text-nowrap">{{ action.year }}</td>
                            <td class="text-nowrap">{{ donor_name }} ➡️ {{ beneficiary_name }}</td>
                            <td class="text-nowrap">{{ action.type|replace({'_':' '}) }}</td>
                            <td class="fw-bold text-end text-nowrap">{{ (action.amount / 100)|number_format(0, ',', ' ') }}</td>
                            {# Masquer le détail sur les téléphones (extra-small screens) #}
                            <td class="d-none d-sm-table-cell small">{{ action.detail }}</td> 
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Utiliser une fonction auto-exécutable pour s'assurer que les variables sont locales
        (function() {
            // Tentative de sélection simple du filtre
            const selectFilter = document.getElementById('filter-relationship');
            
            // Si le sélecteur principal n'est pas trouvé, on arrête.
            if (!selectFilter) {
                console.error("Le sélecteur de filtre (#filter-relationship) n'a pas été trouvé.");
                return;
            }
            
            // Sélection des cartes (on suppose que le DOM est chargé ici)
            const opportunityCards = document.querySelectorAll('.card[data-relationship-type]');

            function applyFilter() {
                const selectedValue = selectFilter.value;
                console.log("Filtre appliqué : " + selectedValue); // DEBUG : Confirmer que la fonction est lancée

                opportunityCards.forEach(card => {
                    const relationshipType = card.getAttribute('data-relationship-type');
                    
                    let shouldShow = false;

                    switch (selectedValue) {
                        case 'all':
                            shouldShow = true;
                            break;
                        
                        case 'descendant':
                            if (relationshipType === 'parent_enfant' || relationshipType === 'grand_parent_petit_enfant') {
                                shouldShow = true;
                            }
                            break;

                        case 'lateral':
                            if (relationshipType === 'frere_soeur') {
                                shouldShow = true;
                            }
                            break;
                            
                        case 'epoux':
                            if (relationshipType === 'epoux') {
                                shouldShow = true;
                            }
                            break;

                        case 'tiers':
                            if (relationshipType === 'tiers' || relationshipType === 'inconnu') {
                                shouldShow = true;
                            }
                            break;
                            
                        default:
                            shouldShow = true;
                            break;
                    }

                    // Basculer la visibilité. Utiliser 'block' pour les éléments normaux.
                    card.style.display = shouldShow ? 'block' : 'none';
                });
            }

            // Écouteur sur le changement de la sélection
            selectFilter.addEventListener('change', applyFilter);
            
            // Déclencher le filtre initialement pour s'assurer que l'état 'all' est appliqué
            // On le lance après un court délai pour être sûr que Bootstrap a fini son travail si nécessaire.
            setTimeout(applyFilter, 50);

        })(); // Fin de la fonction auto-exécutable
    </script>
{% endblock %}